# 🔐 Variables de Entorno - PWA eCommerce
#
# Este archivo muestra las variables de entorno requeridas para la aplicación.
# Copia este archivo como .env.local y ajusta los valores según tu entorno.
#
# IMPORTANTE: Nunca commitees archivos .env con valores reales al repositorio.

# ============================================================================
# 🌐 API Configuration
# ============================================================================

# URL base del backend API
# Producción (Azure):
NG_APP_API_BASE_URL=https://api-ecommerce-d9fxeccbeeehdjd3.eastus-01.azurewebsites.net

# Desarrollo local (mock API):
# NG_APP_API_BASE_URL=http://localhost:5200

# ============================================================================
# 🔔 Firebase Cloud Messaging (FCM)
# ============================================================================

# Clave pública VAPID para notificaciones push
# Obtén esta clave desde Firebase Console > Project Settings > Cloud Messaging
NG_APP_VAPID_PUBLIC_KEY=REPLACE_WITH_YOUR_VAPID_PUBLIC_KEY

# ============================================================================
# 📊 Analytics
# ============================================================================

# Google Analytics Tracking ID
# Formato: G-XXXXXXXXXX o UA-XXXXXXXXX-X
NG_APP_GA_TRACKING_ID=

# Habilitar/deshabilitar analytics
# Valores: true | false
NG_APP_ENABLE_ANALYTICS=false

# ============================================================================
# 🐛 Logging & Debugging
# ============================================================================

# Nivel de logs en consola
# Valores: debug | info | warn | error
NG_APP_LOG_LEVEL=warn

# Habilitar logs en consola (solo para debugging)
# Valores: true | false
# NOTA: En producción debe ser false para mejor performance
NG_APP_ENABLE_CONSOLE=false

# ============================================================================
# 🖼️ Category Images
# ============================================================================

# Tamaño máximo permitido para imagen de categoría (MB)
NG_APP_CATEGORY_IMAGE_MAX_MB=1

# URL pública base para completar imageUrl de categorías
NG_APP_CATEGORY_PUBLIC_BASE_URL=https://pub-49f57cb38af14e108e2f36fb4f0dc058.r2.dev

# ============================================================================
# 📝 Notas de Uso
# ============================================================================
#
# Para desarrollo local con API real:
# 1. Copia este archivo: cp .env.example .env.local
# 2. Ajusta NG_APP_API_BASE_URL a la URL del backend
# 3. Ejecuta: npm run start:real
#
# Para Vercel:
# 1. Ve a Project Settings > Environment Variables
# 2. Agrega cada variable con su valor correspondiente
# 3. Selecciona los entornos: Production, Preview, Development
# 4. Guarda y redeploy
#
# ============================================================================
